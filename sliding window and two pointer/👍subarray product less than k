class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        int l=0;
        int c=0;
        int pro=1;
        if(k==0)
        return 0;
        for(int r=0;r<nums.length;r++)
        {
            pro*=nums[r];
            while(pro>=k && l<=r)
            {
                pro=pro/nums[l];
                l++;
            }
            if(l>r)
            continue;
            c+=r-l+1;
        }
        return c;
    }
}
