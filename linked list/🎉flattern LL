class Solution {
    public Node flatten(Node head) {
        if (head == null) return head;
        
        Node curr = head;
        while (curr != null) {
            // Case 1: No child, just move on
            if (curr.child == null) {
                curr = curr.next;
            } 
            // Case 2: Found a child! Let's stitch it in
            else {
                Node nextNode = curr.next;
                Node childHead = curr.child;
                
                // 1. Connect current node to child head
                curr.next = childHead;
                childHead.prev = curr;
                curr.child = null; // CRITICAL: Clear the child pointer
                
                // 2. Find the tail of the child list
                Node childTail = childHead;
                while (childTail.next != null) {
                    childTail = childTail.next;
                }
                
                // 3. Connect child tail to the original next node
                childTail.next = nextNode;
                if (nextNode != null) {
                    nextNode.prev = childTail;
                }
                
                // 4. Continue from curr (it will now move into the flattened child)
                curr = curr.next;
            }
        }
        return head;
    }
}
